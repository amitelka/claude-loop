#!/usr/bin/env bash
# loopctl — control the self-improving loop. `loopctl` with no args shows status.
set -uo pipefail
_loopdir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"   # bin/.. = loop dir (full-path / cwd invocation)
[ -f "$_loopdir/lib.sh" ] || _loopdir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/loop"   # invoked via a PATH symlink → fall back to the real loop dir
. "$_loopdir/lib.sh" 2>/dev/null || { echo "loop not installed"; exit 1; }
local_cfg="$LOOP_DIR/config.local.sh"   # personal overrides (gitignored), sourced last by config.sh
set_cfg() { touch "$local_cfg"; if grep -q "^$1=" "$local_cfg" 2>/dev/null; then sed -i '' "s|^$1=.*|$1=$2|" "$local_cfg"; else printf '%s=%s\n' "$1" "$2" >> "$local_cfg"; fi; }

cmd="${1:-status}"; shift || true
case "$cmd" in
  status)
    echo "enabled : $LOOP_ENABLED"
    echo "mode    : $LOOP_MODE"
    echo "reviewer: $REVIEWER_MODEL effort=$REVIEWER_EFFORT  (every ${REVIEW_EVERY_TURNS} turns / ${REVIEW_EVERY_TOOLCALLS} tools)"
    echo "gardener: $GARDENER_MODEL effort=$GARDENER_EFFORT"
    echo "pending skills  : $(pending_skill_count)  ($PENDING_SKILLS)"
    echo "pending memories: $(find "$PENDING_MEM" -maxdepth 1 -name '*.md' ! -name '*.WHY.md' 2>/dev/null | wc -l | tr -d ' ')  ($PENDING_MEM)"
    echo "schedule:"; ls "$HOME"/Library/LaunchAgents/io.claudeloop.*.plist 2>/dev/null | sed 's/^/  /' || echo "  (none installed)"
    echo "recent log: ($LOG)"; tail -n 6 "$LOG" 2>/dev/null | sed 's/^/  /'
    ;;
  enable)  set_cfg LOOP_ENABLED 1; echo "loop enabled";;
  disable) set_cfg LOOP_ENABLED 0; echo "loop disabled";;
  mode)
    case "${1:-}" in
      dry-run|active) set_cfg LOOP_MODE "$1"; echo "mode -> $1";;
      *) echo "usage: loopctl mode dry-run|active"; exit 1;;
    esac;;
  review-now)
    proj="$CLAUDE_HOME/projects/$(printf '%s' "$PWD" | sed 's|/|-|g')"
    t="$(ls -t "$proj"/*.jsonl 2>/dev/null | head -1)"
    [ -f "$t" ] || { echo "no transcript for this project ($proj)"; exit 1; }
    session="$(basename "$t" .jsonl)"
    slice="$(mktemp -t loop-slice.XXXXXX)"; cp "$t" "$slice"
    echo "reviewing session $session (mode=$LOOP_MODE) ..."
    bash "$LOOP_DIR/bin/review.sh" "$slice" "$session" "$PWD" "" "manual"
    echo "done. -> loopctl status   (proposals in $PENDING_SKILLS , $PENDING_MEM)"
    ;;
  install-schedule)
    la="$HOME/Library/LaunchAgents"; mkdir -p "$la"
    _agent() { # $1=label $2=hour $3=min $4=command
      cat > "$la/$1.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>$1</string>
  <key>ProgramArguments</key><array><string>/bin/bash</string><string>-lc</string><string>$4</string></array>
  <key>StartCalendarInterval</key><dict><key>Hour</key><integer>$2</integer><key>Minute</key><integer>$3</integer></dict>
  <key>StandardOutPath</key><string>$LOG</string>
  <key>StandardErrorPath</key><string>$LOG</string>
</dict></plist>
PLIST
      launchctl unload "$la/$1.plist" 2>/dev/null
      launchctl load -w "$la/$1.plist" && echo "  loaded $1 (daily $2:$(printf '%02d' "$3"))"
    }
    _agent io.claudeloop.harvest 2 30 "bash $LOOP_DIR/bin/harvest.sh"
    _agent io.claudeloop.garden  3 0  "bash $LOOP_DIR/bin/garden.sh"
    if [ "${SKILL_MINER_ENABLED:-0}" = 1 ]; then
      _agent io.claudeloop.mine-skills 4 0 "bash $LOOP_DIR/bin/mine-skills.sh --scheduled"   # after gardener (3:00); skip-if-unchanged + cadence keep it cheap
    else
      launchctl unload "$la/io.claudeloop.mine-skills.plist" 2>/dev/null; rm -f "$la/io.claudeloop.mine-skills.plist"
      echo "  skill miner not scheduled (SKILL_MINER_ENABLED=0)"
    fi
    echo "scheduled via launchd (daily; a run missed while asleep/off fires on next wake/login)."
    echo "NOTE: unattended runs need a subscription token — run: loopctl token"
    ;;
  uninstall-schedule)
    la="$HOME/Library/LaunchAgents"
    for l in io.claudeloop.harvest io.claudeloop.garden io.claudeloop.mine-skills; do
      [ -f "$la/$l.plist" ] || continue
      launchctl unload "$la/$l.plist" 2>/dev/null
      rm -f "$la/$l.plist" && echo "removed $l"
    done;;
  token)
    echo "Generate a long-lived subscription token, then paste it here (stored chmod 600 in $ENV_FILE)."
    echo "Run in a normal terminal:  claude setup-token"
    printf "paste token> "; read -r tok
    if [ -n "$tok" ]; then umask 077; printf 'export CLAUDE_CODE_OAUTH_TOKEN=%q\n' "$tok" > "$ENV_FILE"; echo "saved to $ENV_FILE"; else echo "skipped"; fi
    ;;
  stats)
    l="$LOG"; g="$MEMORY_DIR"
    echo "── loop stats ──"
    echo "reviews : started=$(grep -c "$TAG_REVIEW_START" "$l" 2>/dev/null)  ok=$(grep -c "$TAG_REVIEW_OK" "$l" 2>/dev/null)  invalid=$(grep -c 'INVALID JSON' "$l" 2>/dev/null)"
    echo "triggers: stop=$(grep -c "$TAG_STOP_TRIGGER" "$l" 2>/dev/null)  session-end=$(grep -c "$TAG_SESSION_END" "$l" 2>/dev/null)  harvest=$(grep -c "$TAG_HARVEST" "$l" 2>/dev/null)  garden=$(grep -c "$TAG_GARDEN_START" "$l" 2>/dev/null)"
    echo "self-heal: presence-spawns=$(grep -c "$TAG_SELFHEAL" "$l" 2>/dev/null)  garden-catchup=$(grep -c "$TAG_GARDEN_CATCHUP" "$l" 2>/dev/null)  miner-catchup=$(grep -c "$TAG_MINER_CATCHUP" "$l" 2>/dev/null)"
    echo "reviews-by-trigger: $(for t in stop session-end harvest manual; do printf '%s=%s ' "$t" "$(grep -c "$TAG_REVIEW_START.*trigger=$t" "$l" 2>/dev/null)"; done)"
    echo "library : global=$(ls "$g"/*.md 2>/dev/null | grep -vc MEMORY.md)  held=$(find "$PENDING_MEM" -maxdepth 1 -name '*.md' ! -name '*.WHY.md' 2>/dev/null | wc -l | tr -d ' ')  pending-skills=$(pending_skill_count)  dropped=$(ls "$ARCHIVE_DIR/dropped"/*.md 2>/dev/null | grep -vc WHY)"
    echo "MEMORY  : $(grep -cE '^- \[' "$g/MEMORY.md" 2>/dev/null) pointers, $(wc -l < "$g/MEMORY.md" 2>/dev/null | tr -d ' ')/$MEMORY_INDEX_MAX_LINES lines"
    echo "snapshots: $(mem_git rev-list --count HEAD 2>/dev/null || echo 0)   last review: $(grep "$TAG_REVIEW_START" "$l" 2>/dev/null | tail -1 | cut -c1-19)"
    ctot=$(grep -oE 'cost=[0-9.]+' "$l" 2>/dev/null | sed 's/cost=//' | awk '{s+=$1} END{printf "%.4f", s+0}')
    cn=$(grep -cE 'cost=[0-9.]+' "$l" 2>/dev/null)
    echo "cost    : \$$ctot across $cn reviews (API-equivalent; subscription not billed per-call)"
    echo "mem git : $(mem_git status --porcelain 2>/dev/null | wc -l | tr -d ' ') uncommitted, $(mem_git rev-list --count HEAD 2>/dev/null || echo 0) snapshots"
    echo "outcomes: +mem=$(grep -c '  +mem ' "$l" 2>/dev/null) +skill=$(grep -c '  +skill ' "$l" 2>/dev/null) dup-skip=$(grep -cE '  skip (mem|skill) .*dup' "$l" 2>/dev/null) rejected=$(grep -cE '  reject (mem|skill)' "$l" 2>/dev/null) anomalies=$(grep -c 'ANOMALY' "$l" 2>/dev/null)"
    ga="$STATE_DIR/garden-actions.jsonl"; gdel=0 gmod=0 gadd=0
    [ -f "$ga" ] && { gdel=$(grep -c '"action":"deleted"' "$ga" 2>/dev/null); gmod=$(grep -c '"action":"modified"' "$ga" 2>/dev/null); gadd=$(grep -c '"action":"added"' "$ga" 2>/dev/null); }
    echo "gardener: pruned/merged=$gdel trimmed=$gmod added=$gadd  regret=$(grep -c '  regret ' "$l" 2>/dev/null)  (regret = gardener-pruned then reviewer-recaptured)"
    sf="$STATE_DIR/skill-miner.state.json"; rj="$STATE_DIR/$REJECT_FILE_NAME"
    ml="$(grep 'mine-skills:' "$l" 2>/dev/null | tail -1)"
    mok="$(jq -r '.last_success_at // empty' "$sf" 2>/dev/null)"; [ -n "$mok" ] && mok="$(date -r "$mok" '+%F %H:%M' 2>/dev/null)"
    rdl=0; [ -f "$rj" ] && rdl="$(wc -l < "$rj" | tr -d ' ')"
    mreal=$(grep "$TAG_MINE_DONE" "$l" 2>/dev/null | grep -c 'dry=0'); mdry=$(grep "$TAG_MINE_DONE" "$l" 2>/dev/null | grep -c 'dry=1')
    msupe=$(grep -oE 'suppressed=\[[^]]*\]' "$l" 2>/dev/null | sed -E 's/suppressed=\[//; s/\]//' | tr ',' '\n' | grep -c '[^[:space:]]')
    echo "miner   : last=$(printf '%s' "$ml" | cut -c1-19 | sed 's/^$/never/') \"$(printf '%s' "$ml" | sed -E 's/^[^ ]+ mine-skills: //' | cut -c1-44)\""
    echo "          runs=$((mreal+mdry)) real=$mreal dry=$mdry fails=$(grep -c "$TAG_MINE_FAILED" "$l" 2>/dev/null)  rejection-denylist=$rdl suppressed-events=$msupe  last-success=${mok:-never}  pending-fail=$([ -f "$STATE_DIR/skill-miner.fail" ] && echo yes || echo no)"
    ;;
  skill-stats)
    f="$STATE_DIR/skill-uses.jsonl"; [ -s "$f" ] || { echo "no skill usage logged yet ($f)"; exit 0; }
    echo "── skill usage (built-in commands excluded) ──"
    jq -s -r '
      (["clear","config","compact","context","help","usage","cost","model","resume","exit","quit","status","login","logout","doctor","mcp","memory","agents","hooks","permissions","vim","terminal-setup","bug","release-notes","add-dir","ide","insights","goal"]) as $b
      | map(select(.skill as $s | ($b | index($s)) | not))
      | group_by(.skill)
      | map({skill:.[0].skill, uses:length, model:(map(select(.via=="model"))|length), user:(map(select(.via=="user"))|length), last:(max_by(.ts).ts)})
      | sort_by(-.uses)[]
      | "  \(.uses)x  \(.skill)  (model:\(.model) user:\(.user))  last \(.last[0:10])"
    ' "$f" 2>/dev/null || echo "  (parse error)"
    ;;
  mine-skills) bash "$LOOP_DIR/bin/mine-skills.sh" "$@";;
  skill-snapshot) skill_snapshot "${1:-manual}"; echo "skills snapshot committed ($SKILLS_DIR)";;
  skill-rollback)
    ref="${1:-}"; [ -n "$ref" ] || { echo "usage: loopctl skill-rollback <commit>   (see: git -C \"$SKILLS_DIR\" log --oneline)"; exit 1; }
    skill_snapshot "pre-rollback"
    skill_git checkout "$ref" -- . && { log "rollback: skills -> $ref"; echo "skills restored to $ref (prior state snapshotted first)"; };;
  skill-curate) bash "$LOOP_DIR/bin/skill-curate.sh";;
  skill-reject)
    n="${1:-}"; [ -n "$n" ] || { echo "usage: loopctl skill-reject <name> [new|patch]"; exit 1; }
    a="${2:-}"; [ -n "$a" ] || { [ -f "$PENDING_SKILLS/$n/PATCH.md" ] && a=patch || a=new; }   # derive from the pending proposal when omitted (PATCH.md → patch)
    case "$a" in new|patch) ;; *) echo "action must be new|patch (got '$a')"; exit 1;; esac
    skill_reject_add "$n" "$a"; echo "rejected: $n ($a) — miner will suppress it (undo: loopctl skill-unreject $n $a)";;
  skill-unreject)
    n="${1:-}"; a="${2:-new}"; [ -n "$n" ] || { echo "usage: loopctl skill-unreject <name> [new|patch]"; exit 1; }
    skill_reject_rm "$n" "$a"; echo "un-rejected: $n ($a) — miner may propose it again";;
  skill-rejections)
    f="$STATE_DIR/$REJECT_FILE_NAME"
    if [ -s "$f" ]; then echo "rejected skill proposals (suppressed from mining):"
      while IFS="$(printf '\t')" read -r n a e; do printf '  %-40s %-6s rejected %s\n' "$n" "$a" "$(date -r "${e:-0}" '+%F' 2>/dev/null || echo '?')"; done < "$f"
    else echo "no rejected skill proposals"; fi;;
  snapshot) mem_snapshot "manual"; echo "memory-global snapshot committed";;
  mem-log)  mem_git log --oneline -20 2>/dev/null || echo "(no snapshots yet — run: loopctl snapshot)";;
  mem-diff) mem_git diff "${1:-HEAD}" 2>/dev/null || echo "(no snapshots yet)";;
  rollback)
    ref="${1:-}"; [ -n "$ref" ] || { echo "usage: loopctl rollback <commit>   (see: loopctl mem-log)"; exit 1; }
    mem_snapshot "pre-rollback"
    mem_git checkout "$ref" -- . && { log "rollback: memory-global -> $ref"; echo "memory-global restored to $ref (prior state saved as a snapshot first)"; };;
  doctor)
    okx(){ echo "  ✓ $1"; }; wrn(){ echo "  ⚠ $1"; }
    echo "── loop doctor ──"
    for hk in Stop SessionStart SessionEnd PostToolUse UserPromptExpansion; do jq -e ".hooks.$hk" "$CLAUDE_HOME/settings.json" >/dev/null 2>&1 && okx "hook $hk wired" || wrn "hook $hk MISSING"; done
    la=$(launchctl list 2>/dev/null | grep -c claudeloop); [ "${la:-0}" -ge 2 ] && okx "launchd: $la agents loaded" || wrn "launchd: ${la:-0}/2 (run: loopctl install-schedule)"
    dd=$(mem_git status --porcelain 2>/dev/null | wc -l | tr -d ' '); [ "${dd:-0}" = 0 ] && okx "memory-global clean" || wrn "memory-global: $dd uncommitted (loopctl snapshot)"
    now="$(date +%s)"; sl=""
    for lk in "$STATE_DIR"/*.lock; do
      [ -d "$lk" ] || continue
      oe="$(awk '{print $3}' "$lk/owner" 2>/dev/null)"
      if printf '%s' "$oe" | grep -qE '^[0-9]+$'; then
        [ "$(( now - oe ))" -gt "${STALE_LOCK_SECS:-7200}" ] && sl="$sl $lk"                  # owner-bearing (store.lock): honor the lock-protocol threshold, not 30m — a live long garden must not be reaped
      else
        [ -n "$(find "$lk" -maxdepth 0 -type d -mmin +30 2>/dev/null)" ] && sl="$sl $lk"       # ownerless session locks: 30m mtime
      fi
    done
    if [ -n "$sl" ]; then echo "$sl" | xargs rm -rf 2>/dev/null; wrn "cleared stale lock(s):$sl"; else okx "no stale locks"; fi
    if [ -f "$ENV_FILE" ]; then case "$(stat -f '%Sp' "$ENV_FILE" 2>/dev/null)" in -rw-------) okx "token present (perms 600)";; *) wrn "token perms not 600";; esac; else wrn "token missing (loopctl token — needed for cron)"; fi
    for t in claude jq perl; do command -v "$t" >/dev/null 2>&1 && okx "tool $t" || wrn "tool $t MISSING"; done
    lh=$(grep 'harvest: nightly pass complete' "$LOG" 2>/dev/null | tail -1 | cut -c1-19); [ -n "$lh" ] && okx "last harvest complete: $lh" || wrn "no completed harvest yet"
    gok="$(cat "$STATE_DIR/garden.success" 2>/dev/null || echo 0)"; now="$(date +%s)"
    gfr=""; [ -f "$STATE_DIR/garden.fail" ] && gfr="; last fail: $(cut -d'|' -f2 "$STATE_DIR/garden.fail")"
    if [ "${gok:-0}" = 0 ]; then wrn "no successful garden recorded yet$gfr"
    elif [ "$((now - gok))" -gt 172800 ]; then wrn "last successful garden >48h ago ($(date -r "$gok" '+%F %H:%M')$gfr)"
    elif [ -f "$STATE_DIR/garden.fail" ]; then wrn "last garden RUN failed ($(cut -d'|' -f2 "$STATE_DIR/garden.fail")) — last success $(date -r "$gok" '+%F %H:%M'); retry pending (Stop hook / next harvest)"
    else okx "last garden ok: $(date -r "$gok" '+%F %H:%M')"; fi
    if [ -f "$STATE_DIR/skill-miner.fail" ]; then wrn "last miner RUN failed ($(cut -d'|' -f2 "$STATE_DIR/skill-miner.fail")) — retry pending (Stop hook / next harvest)"
    elif [ "${SKILL_MINER_ENABLED:-0}" = 1 ]; then okx "miner: no pending failure"; fi
    si=$(find -L "$SKILLS_DIR" -mindepth 2 -maxdepth 2 -name SKILL.md 2>/dev/null | wc -l | tr -d ' ')
    nm=$(find -L "$SKILLS_DIR" -mindepth 2 -maxdepth 2 -name SKILL.md -exec grep -L '^## Triggers' {} + 2>/dev/null | wc -l | tr -d ' ')
    sp=$(pending_skill_count); su=0; [ -f "$STATE_DIR/skill-uses.jsonl" ] && su=$(wc -l < "$STATE_DIR/skill-uses.jsonl" | tr -d ' ')
    echo "  • skills: ${si:-0} installed · ${sp:-0} pending · ${su:-0} usage event(s) · ${nm:-0} missing eval-metadata"
    [ "${sp:-0}" -gt 0 ] && wrn "$sp skill proposal(s) pending → /review-skills"
    echo "    (never-used / stale / archive candidates deferred until telemetry matures — detail: loopctl skill-curate)"
    ;;
  *) echo "usage: loopctl {status|stats|skill-stats|mine-skills [--dry-run]|skill-curate|skill-snapshot|skill-rollback <ref>|doctor|enable|disable|mode dry-run|active|review-now|snapshot|rollback <ref>|mem-log|mem-diff|install-schedule|uninstall-schedule|token}";;
esac
